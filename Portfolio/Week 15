import os
import warnings
import tarfile
import tempfile

import boto3
import joblib
import matplotlib.pyplot as plt
import pandas as pd
import sagemaker
import shap
import streamlit as st

from sagemaker.predictor import Predictor
from sagemaker.serializers import CSVSerializer
from sagemaker.deserializers import JSONDeserializer

warnings.simplefilter("ignore")

st.set_page_config(page_title="HW4 NFLX Pairs Predictor", layout="wide")
st.title("HW4 NFLX Pairs Return Predictor")
st.write("Predict the next-day NFLX return using the best-performing HW4 pairs model.")

aws_id = st.secrets["aws_credentials"]["AWS_ACCESS_KEY_ID"]
aws_secret = st.secrets["aws_credentials"]["AWS_SECRET_ACCESS_KEY"]
aws_token = st.secrets["aws_credentials"]["AWS_SESSION_TOKEN"]
aws_bucket = st.secrets["aws_credentials"]["AWS_BUCKET"]
aws_endpoint = st.secrets["aws_credentials"]["AWS_ENDPOINT"]

FEATURE_NAMES = [
    "EXPD", "TPL", "PGR", "CPRT", "PTC",
    "EXPD_lag1", "TPL_lag1", "PGR_lag1", "CPRT_lag1", "PTC_lag1",
    "EXPD_lag2", "TPL_lag2", "PGR_lag2", "CPRT_lag2", "PTC_lag2"
]

MODEL_INFO = {
    "endpoint": aws_endpoint,
    "explainer": "explainer_hw4.shap",
    "pipeline": "best_hw4_pairs_model.tar.gz",
    "s3_model_prefix": "hw4-pairs-deployment",
    "s3_explainer_key": "explainer/explainer_hw4.shap",
    "keys": FEATURE_NAMES,
    "inputs": [
        {
            "name": feature,
            "type": "number",
            "min": -1.0,
            "max": 1.0,
            "default": 0.0,
            "step": 0.0001,
        }
        for feature in FEATURE_NAMES
    ],
}

@st.cache_resource
def get_boto_session(access_key, secret_key, session_token):
    return boto3.Session(
        aws_access_key_id=access_key,
        aws_secret_access_key=secret_key,
        aws_session_token=session_token,
        region_name="us-east-1",
    )

session = get_boto_session(aws_id, aws_secret, aws_token)
sm_session = sagemaker.Session(boto_session=session)

@st.cache_resource
def load_pipeline(_session, bucket, s3_prefix, pipeline_filename):
    s3_client = _session.client("s3")
    local_tar_path = os.path.join(tempfile.gettempdir(), pipeline_filename)

    if not os.path.exists(local_tar_path):
        s3_client.download_file(
            Bucket=bucket,
            Key=f"{s3_prefix}/{pipeline_filename}",
            Filename=local_tar_path,
        )

    extract_dir = os.path.join(tempfile.gettempdir(), "hw4_model_extract")
    os.makedirs(extract_dir, exist_ok=True)

    with tarfile.open(local_tar_path, "r:gz") as tar:
        tar.extractall(path=extract_dir)
        joblib_files = [name for name in tar.getnames() if name.endswith(".joblib")]

    if not joblib_files:
        raise FileNotFoundError("No .joblib file found in model tar.gz.")

    model_path = os.path.join(extract_dir, joblib_files[0])
    return joblib.load(model_path)

@st.cache_resource
def load_shap_explainer(_session, bucket, s3_key, local_filename):
    s3_client = _session.client("s3")
    local_path = os.path.join(tempfile.gettempdir(), local_filename)

    if not os.path.exists(local_path):
        s3_client.download_file(
            Bucket=bucket,
            Key=s3_key,
            Filename=local_path,
        )

    with open(local_path, "rb") as f:
        return shap.Explainer.load(f)

def call_model_api(input_df: pd.DataFrame):
    predictor = Predictor(
        endpoint_name=MODEL_INFO["endpoint"],
        sagemaker_session=sm_session,
        serializer=CSVSerializer(),
        deserializer=JSONDeserializer(),
    )

    try:
        raw_pred = predictor.predict(input_df.values)
        pred_val = raw_pred[0] if isinstance(raw_pred, list) else raw_pred
        return float(pred_val), 200
    except Exception as e:
        return f"Error: {str(e)}", 500

def display_explanation(input_df: pd.DataFrame):
    try:
        best_pipeline = load_pipeline(
            session,
            aws_bucket,
            MODEL_INFO["s3_model_prefix"],
            MODEL_INFO["pipeline"],
        )

        explainer = load_shap_explainer(
            session,
            aws_bucket,
            MODEL_INFO["s3_explainer_key"],
            MODEL_INFO["explainer"],
        )

        # Apply preprocessing from saved pipeline
        X_processed = best_pipeline.named_steps["imputer"].transform(input_df)
        X_processed = best_pipeline.named_steps["scaler"].transform(X_processed)

        shap_values = explainer(X_processed)

        st.subheader("SHAP Explanation")
        fig = plt.figure(figsize=(10, 5))
        shap.summary_plot(
            shap_values,
            X_processed,
            feature_names=input_df.columns.tolist(),
            show=False,
        )
        st.pyplot(fig)
        plt.close(fig)

        # Top feature from first row
        first_row_vals = shap_values.values[0]
        top_idx = abs(first_row_vals).argmax()
        top_feature = input_df.columns[top_idx]
        top_impact = first_row_vals[top_idx]

        st.info(
            f"Most influential feature: **{top_feature}** "
            f"(SHAP impact: {top_impact:.6f})"
        )

    except Exception as e:
        st.warning(f"Could not generate SHAP explanation: {e}")

with st.form("prediction_form"):
    st.subheader("Enter HW4 Pair Features")

    cols = st.columns(3)
    user_inputs = {}

    for i, inp in enumerate(MODEL_INFO["inputs"]):
        with cols[i % 3]:
            user_inputs[inp["name"]] = st.number_input(
                inp["name"],
                min_value=float(inp["min"]),
                max_value=float(inp["max"]),
                value=float(inp["default"]),
                step=float(inp["step"]),
                format="%.4f",
            )

    submitted = st.form_submit_button("Predict NFLX Return")

if submitted:
    input_df = pd.DataFrame([user_inputs])[MODEL_INFO["keys"]]

    pred, status = call_model_api(input_df)

    if status == 200:
        st.metric("Predicted Next-Day NFLX Return", f"{pred:.6f}")
        display_explanation(input_df)
    else:
        st.error(pred)
